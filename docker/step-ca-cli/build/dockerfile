ARG REGISTRY= \
    OS_TAG=debian:bookworm-slim

# hadolint ignore=DL3006
FROM "${REGISTRY}${OS_TAG}"

# hadolint ignore=SC1091
RUN --mount=from=context,source=pre_install,target=/pre_install \
    set -eux; \
    . /pre_install; \
    install_packs

ARG STEP_CA_VERSION

LABEL maintainer="Agibalov Sergei <agibse@rarus.ru>" \
      version="${STEP_CA_VERSION}" \
      manufacturer="Smallstep Labs"

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# hadolint ignore=SC1091,DL3008
RUN --mount=from=context,source=install,target=/install \
    --mount=from=common_context,target=/common_context \
    --mount=from=context_arg,target=/context_arg \
    set -eux; \
    . common_context/install; \
    . /install; \
    install_packs

COPY --chmod=766 [ "send_sighup.sh", "/" ]
COPY --chmod=766 [ "entrypoint.sh", "/entrypoint.d/entrypoint_step_ca.sh" ]
COPY --from=entrypoint_context --chmod=766 [ "entrypoint.sh", "/" ]

HEALTHCHECK CMD "/healthcheck.sh"

ENTRYPOINT [ "/entrypoint.sh" ]

VOLUME [ "/root/.step/config" ]