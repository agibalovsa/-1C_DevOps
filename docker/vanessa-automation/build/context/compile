#!/usr/bin/env bash

# Compilation of imagemagick deb packages
#  $1 - Project dir
#
compile_project() {

    /usr/bin/Xvfb :99 -screen 0 1024x768x24 2>&1 &
    
    # shellcheck disable=SC2153
    git clone https://github.com/Pr-Mex/vanessa-automation.git \
        && cd vanessa-automation \
        && ([ -n "${VANESSA_VERSION}" ] && git checkout "${VANESSA_VERSION}") \
        && chmod +x compile.sh
    
    DISPLAY=:99.0 ./compile.sh

    kill -9 $(pgrep Xvfb)

    mkdir -p "${1}"
    cp vanessa-automation.epf "${1}"
    zip -r "${1}/vanessa-automation.zip" lib tools docs training vendor examples features locales plugins vanessa-automation.epf

}