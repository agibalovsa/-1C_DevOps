ARG REGISTRY= \
    OS_TAG=debian:bookworm-slim

# hadolint ignore=DL3006
FROM "${REGISTRY}${OS_TAG}"

ARG OC_ELEMENT_VERSION \
    OC_ELEMENT_TYPE

LABEL maintainer="Agibalov Sergei <agibse@rarus.ru>" \
    version="${OC_ELEMENT_TYPE}:${OC_ELEMENT_VERSION}" \
    manufacturer="1C"

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ENV OC_ELEMENT_TYPE=${OC_ELEMENT_TYPE} \
    OC_ELEMENT_VERSION=${OC_ELEMENT_VERSION}

# hadolint ignore=SC1091
RUN --mount=from=context,source=pre_install,target=/pre_install \
    --mount=from=context_arg,target=/context_arg \
    set -eux; \
    . /pre_install; \
    install_packs

# hadolint ignore=SC1091
RUN --mount=from=common_context,target=/common_context \
    --mount=from=context_arg,target=/context_arg \
    set -eux; \
    . /common_context/install; \
    install_packs

COPY --chown=usr1ce:grp1ce --chmod=766 [ "entrypoint.sh", "/entrypoint.d/entrypoint_element.sh" ]
COPY --from=entrypoint_context --chown=usr1ce:grp1ce --chmod=766 [ "entrypoint.sh", "/" ]

HEALTHCHECK CMD /healthcheck.sh

ENTRYPOINT [ "/entrypoint.sh" ]