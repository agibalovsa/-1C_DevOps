# ## OC Server compose options

# ### names

OC_SERVER_NAME="${OC_SERVER_NAME:-oc_server}"
OC_SERVER_TAG="${OC_SERVER_TAG}"
OC_SERVER_HOSTNAME="${OC_SERVER_HOSTNAME}"

# ### configs

# > Template: oc=<mode>
# > For mssql: mssql=mssql oc=server
OC_SERVER_COMMAND="${OC_SERVER_COMMAND:-oc=server}"
# > For windows: C:\Program Files\1cv8\srvinfo
# > For linux: /home/usr1cv8/.1cv8/1C/1cv8
OC_SRVINFO_PATH="${OC_SRVINFO_PATH:-/home/usr1cv8/.1cv8/1C/1cv8}"
# > For windows: C:\ProgramData\1C\licenses
# > For linux: /var/1C/licenses
OC_LIC_PATH="${OC_LIC_PATH:-/var/1C/licenses}"
# > For windows: C:\Program Files\1cv8\logs
# > For linux: /var/log/1C
OC_LOG_PATH="${OC_LOG_PATH:-/var/log/1C}"
# > For windows: C:\Program Files\1cv8\conf
# > For linux: /opt/1cv8/conf
OC_CONF_PATH="${OC_CONF_PATH:-/opt/1cv8/conf}"

# ### resource

HTTP_PORT="${HTTP_PORT:-80}"
OC_RAGENT_PORT="${OC_RAGENT_PORT:-1540}"
OC_RMNGR_PORT="${OC_RMNGR_PORT:-1541}"
OC_RAS_PORT="${OC_RAS_PORT:-1545}"
OC_DEBUG_PORT="${OC_DEBUG_PORT:-1549}"
# Диапазон портов указываем через "-"
OC_RPHOST_PORT="${OC_RPHOST_PORT:-1560-1591}"
OC_SRVINFO_VOL="${OC_SRVINFO_VOL:-oc_srvinfo}"
OC_LIC_VOL="${OC_LIC_VOL:-oc_lic}"
OC_LOG_VOL="${OC_LOG_VOL:-oc_log}"
OC_CONF_VOL="${OC_CONF_VOL:-oc_conf}"
