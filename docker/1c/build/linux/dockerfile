ARG REGISTRY= \
    OS_TAG=debian:bookworm-slim

# hadolint ignore=DL3006
FROM "${REGISTRY}${OS_TAG}"

# hadolint ignore=SC1091
RUN --mount=from=context,source=pre_install,target=/pre_install \
    set -eux; \
    . /pre_install; \
    install_packs

ARG DEBIAN_FRONTEND=noninteractive \
    OC_VERSION \
    OC_MODE \
    OC_GID \
    OC_UID

LABEL maintainer="Agibalov Sergei <agibse@rarus.ru>" \
      version="${OC_MODE}:${OC_VERSION}" \
      manufacturer="1C"

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# hadolint ignore=DL3044
ENV OC_VERSION=${OC_VERSION} \
    OC_PATH="/opt/1cv8/x86_64/${OC_VERSION}"

# hadolint ignore=SC1091
RUN --mount=from=context,source=pre_install_mode,target=/pre_install_mode \
    --mount=from=context_arg,target=/context_arg \
    set -eux; \
    . /pre_install_mode; \
    set_users; \
    install_packs

# hadolint ignore=SC1091
RUN --mount=from=context,source=distr,target=/distr \
    --mount=from=context,source=install,target=/install \
    --mount=from=common_context,target=/common_context \
    --mount=from=context_arg,target=/context_arg \
    set -eux; \
    . /common_context/install; \
    . /install; \
    install_packs

# hadolint ignore=SC1091
RUN --mount=from=context,source=post_install,target=/post_install \
    --mount=from=context_arg,target=/context_arg \
    set -eux; \
    . /post_install; \
    set_startup

COPY --chown=usr1cv8:grp1cv8 --chmod=766 [ "entrypoint.sh", "/entrypoint.d/entrypoint_oc.sh" ]
COPY --from=common_context --chown=usr1cv8:grp1cv8 --chmod=766 [ "entrypoint.sh", "/" ]

HEALTHCHECK CMD /healthcheck.sh

ENTRYPOINT [ "/entrypoint.sh" ]