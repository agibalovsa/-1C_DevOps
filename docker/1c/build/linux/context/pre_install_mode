#!/usr/bin/env bash

# explicitly set user/group IDs
#
set_users() {

    groupadd -r grp1cv8 --gid="${OC_GID:-1000}";
    useradd -r -g grp1cv8 --uid="${OC_UID:-999}" --home-dir=/home/usr1cv8 --shell=/bin/bash usr1cv8;
    mkdir -p /var/1C/licenses /var/log/1C /home/usr1cv8/.1cv8/1C/1cv8/conf /home/usr1cv8/crserver /opt/1cv8/conf;
    chown -R usr1cv8:grp1cv8 /var/1C/licenses /var/log/1C /home/usr1cv8 /opt/1cv8/conf;

}

install_packs() {

    # shellcheck source=/dev/null
    . /context_arg/.arg;

    apt-get update;

    # install ws 1c
    if [ "${OC_MODE_WS}" -eq "1" ]; then
        apt-get install -yq --no-install-recommends apache2;
    fi;

    # install client 1c
    if [ "${OC_MODE_CLIENT}" -eq "1" ]; then
        apt-get install -yq --no-install-recommends libglu1-mesa libcups2 libgtk-3-0 libxxf86vm1 libsm6 libwebkit2gtk-4.0-37 xvfb;
    fi;

    apt-get clean && \
        rm -rf /var/lib/apt/lists/*;

}